# ── ODsay 대중교통 경로 API (실제 지하철 경로 탐색용) ────────────────────
# 카카오맵은 지하철 환승 경로를 계산해주는 공개 REST API를 제공하지 않아서
# (지도 앱 UI 안에서만 제공), 대신 국내 대중교통 경로 탐색용으로 널리 쓰이는
# ODsay를 사용합니다. https://lab.odsay.com 에서 무료로 발급받을 수 있습니다.
# 비워두면 이 기능은 자동으로 꺼지고, 기존처럼 내부에 등록된 제한적인
# 역/구간 데이터 기준(BFS) 경로로만 안내합니다.
ODSAY_API_KEY=

# ── 서울 열린데이터광장 / 공공데이터포털 API 키 ──────────────────────────
# 1) 서울교통공사_편의시설위치정보 (엘리베이터 설치·실시간 고장 여부)
#    https://www.data.go.kr/data/15143841/openapi.do
# 2) 서울교통공사_빠른하차정보 (엘리베이터/휠체어리프트와 가장 가까운 승하차 문 위치)
#    https://www.data.go.kr/data/15143840/openapi.do
# 3) 서울교통공사_지하철역 교통약자이용정보(휠체어리프트) — 편의시설위치정보와
#    같은 데이터셋에 포함되어 있으면 별도 URL 없이 자동으로 같이 조회됩니다.
#    만약 완전히 별도 오퍼레이션으로 발급받았다면 아래 LIFT_API_URL에 넣으세요.
# 둘 다 공공데이터포털(data.go.kr)에서 "활용신청" 후 발급되는 서비스키를
# 그대로 사용하면 됩니다. (서울열린데이터광장에도 동일 데이터가 미러링되어
# 있는 경우 SEOUL_API_KEY 로 별도 신청/사용 가능)

# 휠체어리프트 전용 오퍼레이션 URL (비워두면 FACILITY_API_URL과 같은 데이터셋을
# "리프트" 키워드로 필터링해서 재사용합니다 — 대부분 이걸로 충분합니다)
LIFT_API_URL=

# 공공데이터포털 odcloud 휠체어리프트 API 키 (국토교통부_철도역 휠체어리프트)
# https://www.data.go.kr/data/15130663/openapi.do 에서 활용신청 후 발급
# 이 키가 있으면 mtrWheelLift(서울열린데이터광장)보다 우선 사용됩니다.
ODCLOUD_LIFT_API_KEY=

# 공공데이터포털 서비스키 (인코딩된 값 그대로 붙여넣기)
DATA_GO_KR_SERVICE_KEY=여기에_발급받은_서비스키_입력

# 서울열린데이터광장에서 직접 신청한 경우 (선택)
SEOUL_OPEN_DATA_API_KEY=

# ── 서울열린데이터광장 전용 API 3종 (요청주신 키가 코드에 기본값으로 이미
#    들어있어서 비워둬도 동작하지만, 필요하면 여기서 덮어쓸 수 있습니다) ──
# 1) 서울시 빠른하차정보 현황 (getFstExit)
#    http://openapi.seoul.go.kr:8088/{키}/xml/getFstExit/1/5/
SEOUL_QUICK_EXIT_API_KEY=684f6e794464736b373965644b4e5a

# 2) 서울교통공사_휠체어리프트 설치현황 (mtrWheelLift)
#    http://openapi.seoul.go.kr:8088/{키}/xml/mtrWheelLift/1/5/
SEOUL_LIFT_API_KEY=665863466364736b3833496a517166

# 3) 서울시 지하철 실시간 도착정보(일괄제공) (realtimeStationArrival)
#    http://swopenAPI.seoul.go.kr/api/subway/{키}/xml/realtimeStationArrival/ALL
SEOUL_REALTIME_ARRIVAL_API_KEY=446d4e786b64736b3631746a697164

# true 로 두면 실제 API 대신 목(mock) 데이터를 사용합니다.
# API 키를 아직 발급받지 못했을 때 로컬 개발/시연용으로 사용하세요.
USE_MOCK_ELEVATOR_API=true

# 서버 포트
PORT=3000

# 엘리베이터 상태 캐시 갱신 주기 (밀리초). 기본 3분.
ELEVATOR_REFRESH_INTERVAL_MS=180000
